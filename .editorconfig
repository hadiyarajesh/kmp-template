root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_code_style = android_studio
max_line_length = 100
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[**/build/**]
ktlint = disabled

[**/generated/**]
ktlint = disabled
